# Coolify Deployment Environment Variables
# Set these in Coolify UI → Environment Variables

# Database (NeonDB PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database_name

# Redis (auto-set if using Coolify Redis, otherwise use docker-compose internal)
REDIS_URL=redis://redis:6379

# Google Gemini AI API Key
GOOGLE_API_KEY=your_google_api_key_here

# JWT Secret for authentication (generate a long random string)
JWT_SECRET=your_jwt_secret_here_make_it_long_and_random

# Frontend URL (your frontend Coolify domain)
FRONTEND_URL=https://your-frontend-domain.coolify.app

# Backend API URL (your backend Coolify domain + /api)
NEXT_PUBLIC_API_URL=https://your-backend-domain.coolify.app/api
